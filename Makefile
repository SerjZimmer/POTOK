# Makefile для проекта POTOK
# Этот файл упрощает выполнение рутинных задач разработки.

# Цель по умолчанию, которая выполняется при запуске `make` без аргументов.
.DEFAULT_GOAL := help

# .PHONY гарантирует, что цели будут выполняться, даже если существуют файлы с такими же именами.
.PHONY: help clean run

# Показывает список доступных команд.
help:
	@echo "Добро пожаловать в проект POTOK!"
	@echo "Использование: make [цель]"
	@echo ""
	@echo "Доступные цели:"
	@echo "  run           - Показать инструкцию по запуску всего приложения."
	@echo "  clean         - Очистить временные файлы сборки и БД."
	@echo "  help          - Показать это справочное сообщение."

# Удаляет временные файлы и базу данных.
clean:
	@echo "--> Очищаю артефакты..."
	@rm -f backend/potok.db
	@echo "--> Очистка завершена."

# Предоставляет инструкцию по запуску всего приложения.
run:
	@echo "--> Чтобы запустить приложение, пожалуйста, откройте два отдельных окна терминала:"
	@echo ""
	@echo "    В Терминале 1 выполните: cd backend && make run"
	@echo "    В Терминале 2 выполните: cd frontend && make run"
	@echo ""